	path = upstream/strace
	url = https://github.com/strace/strace.git
[submodule "upstream/gdb"]
	path = upstream/gdb
	url = https://github.com/gnutools/binutils-gdb.git
	shallow = true
[submodule "upstream/nmap"]
	path = upstream/nmap
	url = https://github.com/nmap/nmap.git
	shallow = true
[submodule "upstream/jq"]
	path = upstream/jq
